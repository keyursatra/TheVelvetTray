# ─── Core ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# ─── Database ─────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/velvettray

# ─── Auth ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-prod-access
JWT_REFRESH_SECRET=change-me-in-prod-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost

# ─── Rate limits ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ─── Razorpay (provided later) ───────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Shipping (provided later) ───────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ─── Email (provided later) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="The Velvet Tray <hello@thevelvettray.com>"

# ─── Admin seed ──────────────────────────────────────
SEED_ADMIN_EMAIL=admin@thevelvettray.com
SEED_ADMIN_PASSWORD=ChangeMeNow!2026
